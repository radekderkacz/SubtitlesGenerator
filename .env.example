# ─────────────────────────────────────────────────────────────────────────────
# SubtitlesGenerator — required environment for docker-compose.yml.
#
# Copy to `.env` (which is gitignored) and fill in real values.
#
#     cp .env.example .env
#     $EDITOR .env
#
# Everything else (Whisper endpoint, translation provider, Jellyfin URL,
# AI profiles, watch triggers, scheduled scans) is configured at runtime
# in the web UI at http://<host>:8000/settings.
# ─────────────────────────────────────────────────────────────────────────────

# Absolute path on YOUR docker host where your video library lives. This
# is the LEFT side of the compose volume mappings — wherever your movies,
# TV shows, etc. are mounted (NFS, SMB, local disk, USB, anything).
#
# Inside the container this is always mounted at /media; the worker writes
# the .srt next to the source video, so the path must be writable.
#
# Examples:
#   MEDIA_HOST_PATH=/srv/media
#   MEDIA_HOST_PATH=/mnt/nas
#   MEDIA_HOST_PATH=/home/me/Videos
MEDIA_HOST_PATH=/srv/media

# Postgres password (used internally by the db service + the app/worker
# connection strings). Any string; pick something long and random.
DB_PASSWORD=replace-with-a-long-random-string

# FastAPI session/signing key. Any random string; not used by anything
# user-facing yet, but reserved so it can be rotated without a code change.
SECRET_KEY=replace-with-a-long-random-string
